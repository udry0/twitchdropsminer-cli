# Konfigurasi akun Twitch Drops Miner (per akun)
# Simpan file ini sebagai accounts/acc1/.env, accounts/acc2/.env, dst.

# Nama akun/instance. Dipakai runner untuk pilih folder kerja masing-masing akun.
TDM_ACCOUNT_NAME=acc1

# Prioritas game. Pisahkan dengan koma.
TDM_PRIORITY=Legend of YMIR

# Game yang mau diabaikan.
TDM_EXCLUDE=

# priority-only | ending-soonest | low-availability-first
TDM_PRIORITY_MODE=priority-only

# 1..6
TDM_CONNECTION_QUALITY=3

# 1 untuk aktifkan extra available drops check
TDM_AVAILABLE_DROPS_CHECK=0

# Isi 1 kalau mau paksa kirim --no-available-drops-check
TDM_FORCE_DISABLE_DROPS_CHECK=1

# Opsional: -v, -vv, -vvv, -vvvv
TDM_VERBOSE=-vv

# Argumen tambahan mentah
TDM_EXTRA_ARGS=
